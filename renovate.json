{
  "extends": ["config:base"],
  "regexManagers": [
    {
      "fileMatch": ["^files/build_base\\.sh$"],
      "matchStrings": [
        "OPENSSL_VERSION=\"(?<prefix>openssl-)(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "openssl/openssl",
      "extractVersionTemplate": "^openssl-(?<version>.*)$",
      "autoReplaceStringTemplate": "OPENSSL_VERSION=\"{{{prefix}}}{{{newValue}}}\"",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["build\\.sh"],
      "matchStrings": [
        "SQLCIPHER_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "sqlcipher/sqlcipher"
    }
  ]
}
